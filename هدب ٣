let leaves = [
  {empIdx:0,type:'سنوية',from:'2026-07-01',to:'2026-07-10',status:'موافق عليها'},
  {empIdx:3,type:'مرضية',from:today,to:today,status:'موافق عليها'},
];

function switchTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='employees') renderEmployees();
  else if(name==='attendance') renderAttendance();
  else if(name==='leaves') renderLeaves();
  else if(name==='salaries') renderSalaries();
}

function initials(n){return n.trim().split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()}

function badge(s){
  const map={
    'حاضر':'b-present','غائب':'b-absent','متأخر':'b-late','إجازة':'b-leave',
    'نشط':'b-active','موقوف':'b-inactive',
    'معلقة':'b-pending','موافق عليها':'b-approved','مرفوضة':'b-rejected'
  };
  return`<span class="badge ${map[s]||''}">${s}</span>`;
}

function iqamaStyle(d){
  const diff=(new Date(d)-new Date())/86400000;
  if(diff<30) return'exp-soon';
  if(diff<90) return'exp-warn';
  return'';
}

/* ─── EMPLOYEES ─── */
function renderEmployees(){
  const q=(document.getElementById('searchEmp').value||'').toLowerCase();
  const sf=document.getElementById('filterStatus').value;
  const rows=employees.map((e,i)=>{
    if(q&&!e.name.includes(q)&&!e.dept.toLowerCase().includes(q)) return'';
    if(sf&&e.status!==sf) return'';
    const cls=iqamaStyle(e.iqamaExp);
    return`<tr>
      <td><div class="td-name"><div class="avatar">${initials(e.name)}</div>${e.name}</div></td>
      <td>${e.dept}</td>
      <td>${e.phone||'—'}</td>
      <td>${e.iqama||'—'}</td>
      <td class="${cls}">${e.iqamaExp||'—'}</td>
      <td>${(e.salary||0).toLocaleString()} ر.س</td>
      <td>${badge(e.status)}</td>
      <td>
        <div class="action-btns">
          <button class="act-btn act-edit" onclick="openEditEmp(${i})">✏️ تعديل</button>
          <button class="act-btn act-del" onclick="deleteEmp(${i})">🗑️</button>
        </div>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('empBody').innerHTML=rows||'<tr><td colspan="8" class="empty">لا توجد نتائج</td></tr>';
  updateStats();
}

function openAddEmp(){
  editEmpIdx=-1;
  document.getElementById('empModalTitle').textContent='إضافة موظف جديد';
  document.getElementById('fName').value='';
  document.getElementById('fPhone').value='';
  document.getElementById('fIqama').value='';
  document.getElementById('fIqamaExp').value='';
  document.getElementById('fSalary').value='';
  document.getElementById('fNotes').value='';
  document.getElementById('fHire').value=today;
  document.getElementById('fStatus').value='نشط';
  document.getElementById('fDept').value='المبيعات';
  document.getElementById('empModal').classList.add('open');
}

function openEditEmp(i){
  editEmpIdx=i;
  const e=employees[i];
  document.getElementById('empModalTitle').textContent='تعديل: '+e.name;
  document.getElementById('fName').value=e.name;
  document.getElementById('fDept').value=e.dept;
  document.getElementById('fPhone').value=e.phone||'';
  document.getElementById('fIqama').value=e.iqama||'';
  document.getElementById('fIqamaExp').value=e.iqamaExp||'';
  document.getElementById('fSalary').value=e.salary||'';
  document.getElementById('fHire').value=e.hire||'';
  document.getElementById('fStatus').value=e.status;
  document.getElementById('fNotes').value=e.notes||'';
  document.getElementById('empModal').classList.add('open');
}

function saveEmployee(){
  const emp={
    name:document.getElementById('fName').value||'موظف جديد',
    dept:document.getElementById('fDept').value,
    phone:document.getElementById('fPhone').value,
    iqama:document.getElementById('fIqama').value,
    iqamaExp:document.getElementById('fIqamaExp').value,
    salary:parseInt(document.getElementById('fSalary').value)||0,
    hire:document.getElementById('fHire').value,
    status:document.getElementById('fStatus').value,
    notes:document.getElementById('fNotes').value,
  };
  if(editEmpIdx>=0) employees[editEmpIdx]=emp;
  else employees.push(emp);
  closeModal('empModal');
  renderEmployees();
}

function deleteEmp(i){
  if(!confirm('هل أنت متأكد من حذف هذا الموظف؟')) return;
  employees.splice(i,1);
  attendance=attendance.filter(a=>a.empIdx!==i).map(a=>({...a,empIdx:a.empIdx>i?a.empIdx-1:a.empIdx}));
  leaves=leaves.filter(l=>l.empIdx!==i).map(l=>({...l,empIdx:l.empIdx>i?l.empIdx-1:l.empIdx}));
  renderEmployees();
}

/* ─── ATTENDANCE ─── */
function renderAttendance(){
  const d=document.getElementById('attDate').value;
  const f=document.getElementById('attFilter').value;
  const rows=employees.map((_,i)=>{
    const rec=attendance.find(a=>a.empIdx===i&&a.date===d);
    const s=rec?rec.status:'—';
    if(f&&s!==f) return'';
    const e=employees[i];
    return`<tr>
      <td><div class="td-name"><div class="avatar">${initials(e.name)}</div>${e.name}</div></td>
      <td>${e.dept}</td>
      <td>${rec&&rec.in||'—'}</td>
      <td>${rec&&rec.out||'—'}</td>
      <td>${rec?badge(s):'<span style="color:var(--text-muted)">—</span>'}</td>
      <td>
        <div class="action-btns">
          <button class="act-btn act-edit" onclick="openEditAtt(${i},'${d}')">✏️ تعديل</button>
        </div>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('attBody').innerHTML=rows||'<tr><td colspan="6" class="empty">لا يوجد سجل لهذا اليوم</td></tr>';
}

function openEditAtt(empIdx,date){
  const rec=attendance.find(a=>a.empIdx===empIdx&&a.date===date);
  const sel=document.getElementById('aEmp');
  sel.innerHTML=employees.map((e,i)=>`<option value="${i}">${e.name}</option>`).join('');
  sel.value=empIdx;
  document.getElementById('aDate').value=date;
  document.getElementById('aStatus').value=rec?rec.status:'حاضر';
  document.getElementById('aIn').value=rec&&rec.in||'08:00';
  document.getElementById('aOut').value=rec&&rec.out||'17:00';
  document.getElementById('attModalTitle').textContent=rec?'تعديل سجل الحضور':'تسجيل حضور جديد';
  document.getElementById('attModal').classList.add('open');
}

function saveAttendance(){
  const idx=parseInt(document.getElementById('aEmp').value);
  const d=document.getElementById('aDate').value;
  const rec={empIdx:idx,date:d,status:document.getElementById('aStatus').value,in:document.getElementById('aIn').value,out:document.getElementById('aOut').value};
  const ex=attendance.findIndex(a=>a.empIdx===idx&&a.date===d);
  if(ex>=0) attendance[ex]=rec; else attendance.push(rec);
  closeModal('attModal');
  renderAttendance();
  updateStats();
}

/* ─── LEAVES ─── */
function renderLeaves(){
  const f=document.getElementById('leaveFilter').value;
  const rows=leaves.map((l,i)=>{
    if(f&&l.status!==f) return'';
    const e=employees[l.empIdx];
    if(!e) return'';
    const days=Math.max(1,Math.round((new Date(l.to)-new Date(l.from))/86400000)+1);
    return`<tr>
      <td><div class="td-name"><div class="avatar">${initials(e.name)}</div>${e.name}</div></td>
      <td>${l.type}</td>
      <td>${l.from}</td>
      <td>${l.to}</td>
      <td>${days}</td>
      <td>${badge(l.status)}</td>
      <td>
        <div class="action-btns">
          <button class="act-btn act-edit" onclick="openEditLeave(${i})">✏️ تعديل</button>
          <button class="act-btn act-del" onclick="deleteLeave(${i})">🗑️</button>
        </div>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('leaveBody').innerHTML=rows||'<tr><td colspan="7" class="empty">لا توجد إجازات</td></tr>';
}

function openAddLeave(){
  editLeaveIdx=-1;
  const sel=document.getElementById('lEmp');
  sel.innerHTML=employees.map((e,i)=>`<option value="${i}">${e.name}</option>`).join('');
  document.getElementById('lFrom').value=today;
  document.getElementById('lTo').value=today;
  document.getElementById('lStatus').value='معلقة';
  document.getElementById('lType').value='سنوية';
  document.getElementById('leaveModalTitle').textContent='طلب إجازة جديد';
  document.getElementById('leaveModal').classList.add('open');
}

function openEditLeave(i){
  editLeaveIdx=i;
  const l=leaves[i];
  const sel=document.getElementById('lEmp');
  sel.innerHTML=employees.map((e,idx)=>`<option value="${idx}">${e.name}</option>`).join('');
  sel.value=l.empIdx;
  document.getElementById('lType').value=l.type;
  document.getElementById('lStatus').value=l.status;
  document.getElementById('lFrom').value=l.from;
  document.getElementById('lTo').value=l.to;
  document.getElementById('leaveModalTitle').textContent='تعديل الإجازة';
  document.getElementById('leaveModal').classList.add('open');
}

function saveLeave(){
  const leave={
    empIdx:parseInt(document.getElementById('lEmp').value),
    type:document.getElementById('lType').value,
    from:document.getElementById('lFrom').value,
    to:document.getElementById('lTo').value,
    status:document.getElementById('lStatus').value,
  };
  if(editLeaveIdx>=0) leaves[editLeaveIdx]=leave;
  else leaves.push(leave);
  closeModal('leaveModal');
  renderLeaves();
  updateStats();
}

function deleteLeave(i){
  if(!confirm('حذف هذه الإجازة؟')) return;
  leaves.splice(i,1);
  renderLeaves();
  updateStats();
}

/* ─── SALARIES ─── */
function renderSalaries(){
  const rows=employees.map(e=>{
    const deduct=Math.round(e.salary*0.05);
    const allow=Math.round(e.salary*0.15);
    const net=e.salary-deduct+allow;
    return`<tr>
      <td><div class="td-name"><div class="avatar">${initials(e.name)}</div>${e.name}</div></td>
      <td>${e.dept}</td>
      <td>${e.salary.toLocaleString()}</td>
      <td style="color:var(--danger)">${deduct.toLocaleString()}</td>
      <td style="color:var(--success)">${allow.toLocaleString()}</td>
      <td style="font-weight:700">${net.toLocaleString()}</td>
      <td>${badge('موافق عليها')}</td>
    </tr>`;
  }).join('');
  document.getElementById('salBody').innerHTML=rows||'<tr><td colspan="7" class="empty">لا توجد بيانات</td></tr>';
}

/* ─── STATS ─── */
function updateStats(){
  document.getElementById('sTotal').textContent=employees.length;
  const present=attendance.filter(a=>a.date===today&&(a.status==='حاضر'||a.status==='متأخر')).length;
  document.getElementById('sPresent').textContent=present;
  const onLeave=leaves.filter(l=>l.from<=today&&l.to>=today&&l.status==='موافق عليها').length;
  document.getElementById('sLeave').textContent=onLeave;
  const total=employees.reduce((s,e)=>s+(e.salary||0),0);
  document.getElementById('sSalary').textContent=total.toLocaleString()+' ر.س';
}

function closeModal(id){document.getElementById(id).classList.remove('open')}
document.querySelectorAll('.modal-bg').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open')}));

renderEmployees();
renderAttendance();
</script>
</body>
</html>
