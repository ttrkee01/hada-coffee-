      <button class="btn btn-primary" onclick="saveLeave()">💾 حفظ</button>
    </div>
  </div>
</div>

<script>
const today = new Date().toISOString().split('T')[0];
document.getElementById('dateStr').textContent = new Date().toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
