let attendance = [
  {empIdx:0,date:today,status:'حاضر',in:'08:05',out:'17:00'},
  {empIdx:1,date:today,status:'متأخر',in:'09:30',out:'17:00'},
  {empIdx:2,date:today,status:'حاضر',in:'07:55',out:'17:00'},
