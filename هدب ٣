        <tbody id="empBody"></tbody>
      </table>
    </div>
  </div>

  <!-- TAB: ATTENDANCE -->
  <div id="tab-attendance" class="panel">
    <div class="toolbar">
      <input type="date" id="attDate" style="max-width:170px;flex:none">
      <select id="attFilter" onchange="renderAttendance()" style="max-width:140px">
        <option value="">كل الحالات</option>
        <option value="حاضر">حاضر</option>
        <option value="غائب">غائب</option>
        <option value="متأخر">متأخر</option>
        <option value="إجازة">إجازة</option>
      </select>
      <button class="btn" onclick="renderAttendance()">🔄 تحديث</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="width:170px">الموظف</th>
            <th style="width:100px">القسم</th>
            <th style="width:100px">وقت الدخول</th>
            <th style="width:100px">وقت الخروج</th>
            <th style="width:90px">الحالة</th>
            <th style="width:140px">إجراءات</th>
          </tr>
        </thead>
        <tbody id="attBody"></tbody>
      </table>
    </div>
  </div>

  <!-- TAB: LEAVES -->
  <div id="tab-leaves" class="panel">
    <div class="toolbar">
      <select id="leaveFilter" onchange="renderLeaves()" style="max-width:150px">
        <option value="">كل الحالات</option>
        <option value="معلقة">معلقة</option>
        <option value="موافق عليها">موافق عليها</option>
        <option value="مرفوضة">مرفوضة</option>
      </select>
      <button class="btn btn-primary" onclick="openAddLeave()">+ طلب إجازة</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="width:170px">الموظف</th>
            <th style="width:100px">نوع الإجازة</th>
            <th style="width:105px">من</th>
            <th style="width:105px">إلى</th>
            <th style="width:65px">الأيام</th>
            <th style="width:100px">الحالة</th>
            <th style="width:140px">إجراءات</th>
          </tr>
        </thead>
        <tbody id="leaveBody"></tbody>
      </table>
    </div>
  </div>

  <!-- TAB: SALARIES -->
  <div id="tab-salaries" class="panel">
    <div class="toolbar">
      <select id="salMonth" style="max-width:170px">
        <option>يناير 2026</option><option>فبراير 2026</option><option>مارس 2026</option>
