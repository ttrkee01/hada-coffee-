            <th style="width:115px">رقم الإقامة</th>
            <th style="width:105px">انتهاء الإقامة</th>
            <th style="width:90px">الراتب</th>
            <th style="width:80px">الحالة</th>
            <th style="width:140px">إجراءات</th>
          </tr>
