    <button class="tab-btn" onclick="switchTab('salaries',this)">💰 الرواتب</button>
  </div>

  <!-- TAB: EMPLOYEES -->
  <div id="tab-employees" class="panel active">
    <div class="toolbar">
      <input type="text" id="searchEmp" placeholder="🔍 بحث باسم الموظف أو القسم..." oninput="renderEmployees()">
